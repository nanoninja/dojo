{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "debug-up",
            "type": "shell",
            "command": "make debug-up",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "debug-down",
            "type": "shell",
            "command": "make debug-down",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "lint",
            "type": "shell",
            "command": "make lint",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true
            },
            "problemMatcher": "$go"
        },
        {
            "label": "test",
            "type": "shell",
            "command": "make test",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared",
                "focus": false
            },
            "problemMatcher": "$go"
        }
    ]
}
