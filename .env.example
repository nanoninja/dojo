# Application
APP_NAME=dojo
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENCRYPTION_KEY=change-me-32-bytes-in-production

# Database
DB_HOST=db
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=admin
DB_NAME=dojo
DB_SSLMODE=require
DB_SSLROOTCERT=/path/to/ca.pem
DB_SSLCERT=/path/to/client-cert.pem
DB_SSLKEY=/path/to/client-key.pem

# Database connection pool
DB_POOL_MAX_OPEN=25
DB_POOL_MAX_IDLE=10
DB_POOL_CONN_MAX_LIFETIME_SECONDS=300
DB_POOL_CONN_MAX_IDLE_SECONDS=120

# Redis
REDIS_ADDR=cache:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MAX_RETRIES=3
REDIS_DIAL_TIMEOUT_SECONDS=5
REDIS_READ_TIMEOUT_SECONDS=3
REDIS_WRITE_TIMEOUT_SECONDS=3

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=7

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:4200

# Mailer
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

MAIL_DISPATCH_ENABLED=true
MAIL_TIMEOUT_MS=3000
MAIL_RETRY_ATTEMPTS=3
MAIL_RETRY_BASE_DELAY_MS=200

# Seed
SEED_SUPERADMIN_EMAIL=admin@example.com
SEED_SUPERADMIN_PASSWORD=ChangeMe1!
SEED_SYSTEM_EMAIL=system@internal.local

# Audit log purge
AUDIT_PURGE_ENABLED=true
AUDIT_PURGE_RETENTION_DAYS=90
AUDIT_PURGE_BATCH_SIZE=100
AUDIT_PURGE_BATCH_PAUSE_SECONDS=300
AUDIT_PURGE_SCHEDULE_HOUR=2

# Auth Transport (security)
AUTH_TRANSPORT_MODE=dual
AUTH_COOKIE_ACCESS_NAME=access_token
AUTH_COOKIE_REFRESH_NAME=refresh_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/
AUTH_COOKIE_SAMESITE=lax

# Metrics
# Comma-separated list of IPs allowed to access /metrics. Empty = unrestricted (dev).
METRICS_ALLOWED_IPS=